{
  "highlight.regexes": {
    // 1. SEPARADORES DE SECCIÓN — líneas "# ──..." en verde negrita
    "(# ──[^\n]*)": {
      "filterFileRegex": ".*\\.md",
      "decorations": [
        { "color": "#6A9955", "fontWeight": "bold" }
      ]
    },

    // 2. CONSTANTES SNAKE_CASE — en verde lima
    "\\b([A-Z][A-Z0-9]*(?:_[A-Z0-9]+)+)\\b": {
      "filterFileRegex": ".*\\.md",
      "decorations": [
        { "color": "#B8D7A3" }
      ]
    },

    // 3. COMENTARIOS AL FINAL DE LÍNEA — # texto en verde italica
    "\\s+(#[^\n]+)": {
      "filterFileRegex": ".*\\.md",
      "decorations": [
        { "color": "#6A9955", "fontStyle": "italic" }
      ]
    },

    // 4a. NEGRITAS EN LISTAS — "- **texto**" en naranja negrita
    "^\\s*- (\\*\\*[^*\\n]+\\*\\*)": {
      "filterFileRegex": ".*\\.md",
      "regexFlags": "gm",
      "decorations": [
        { "color": "#E8A64C", "fontWeight": "bold" }
      ]
    },

    // 4b. NEGRITAS SUELTAS (no en listas) — "**texto**" en azul negrita
    "^([^-\\s].*?)?(\\*\\*[^*\\n]+\\*\\*)": {
      "filterFileRegex": ".*\\.md",
      "regexFlags": "gm",
      "decorations": [
        {},
        { "color": "#569CD6", "fontWeight": "bold" }
      ]
    },

    // 5. TEXTO ENTRE COMILLAS — en salmon/naranja
    "(\"[^\"\\n]+\")": {
      "filterFileRegex": ".*\\.md",
      "decorations": [
        { "color": "#CE9178" }
      ]
    }
  }
}