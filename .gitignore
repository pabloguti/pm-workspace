# ── Claude Code internals ─────────────────────────────────────────────────────
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/sessions/
.pr-plan-ok

# ── Credenciales y secretos — NUNCA commitear ────────────────────────────────
.claude/.env
.claude/settings.local.json
.claude/profiles/active-user.md
.env
.env.*
*.pat
*.secret
*.pem
*.key
*.p12
*.pfx
**/*-secret*
**/*-credentials*
**/*-secrets*

# ── Proyectos: todo ignorado por defecto, solo se publican los de ejemplo ─────
# Cualquier proyecto nuevo queda automáticamente excluido sin necesidad de
# nombrarlo aquí. Solo se declaran explícitamente los proyectos de ejemplo.
projects/*
!projects/README.md
!projects/PROJECT_TEMPLATE.md
!projects/proyecto-alpha/
!projects/proyecto-beta/
!projects/sala-reservas/
!projects/savia-mobile-android/
!projects/savia-web/
!projects/savia-monitor/

# ── Datos generados y sensibles (incluso dentro de proyectos de ejemplo) ──────
projects/*/sprints/
projects/*/test-data/
projects/*/source/

# ── Datos de equipo con información personal (RGPD) ──────────────────────────
projects/*/evaluaciones/
projects/*/privacy/
projects/*/onboarding/

# ── Outputs generados ────────────────────────────────────────────────────────
output/
/tmp/

# ── Node ─────────────────────────────────────────────────────────────────────
**/node_modules/
**/package-lock.json
**/dist/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ── Binarios ──────────────────────────────────────────────────────────────────
*.apk
*.aab
*.ipa

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Configuración privada de reglas ──────────────────────────────────────────
.claude/rules/pm-config.local.md

# ── Perfiles de usuario (datos personales — RGPD) ──────────────────────────
# Solo se commitea la plantilla. Perfiles reales son privados.
.claude/profiles/users/*
!.claude/profiles/users/template/

# ── Claude Code — preferencias personales (no compartir) ─────────────────────
CLAUDE.local.md

# ── Agent memory — tres niveles ──────────────────────────────────────────────
# public-agent-memory/    ← SI en git (best practices genericas, sin PII)
# private-agent-memory/   ← NO en git (contexto personal, equipo, proyectos)
# projects/*/agent-memory/ ← NO en git (datos especificos de cada proyecto)
.claude/agent-memory/
.claude/agent-memory-local/
private-agent-memory/

# ── Decision log — privado del PM ─────────────────────────────────────────────
decision-log.md

# ── Perfiles de miembros del equipo (datos personales — RGPD) ──────────────
# Contienen nombre, email, localidad, vacaciones. Solo se commitea la plantilla.
# Estructura de equipos (dept.md, team.md, deps.md) SÍ se commitea.
teams/*
!teams/members/template.md

# ── Confidence Log — Datos privados del sistema de calibración ─────────────────
/data/*
!/data/agent-actuals.example.jsonl
backups/

# Capturas de pantalla de los test
scripts/tests/screenshots

# Configuraciones locales
.claude/settings.local.*
scripts/confidentiality-blocklist.local.txt

# Informes de auditoria
audit-report-*

# Backups
*.backup

#Context cache
.claude/context-cache/

#Local Settings
.claude/settings.local.json

# ── Dev-session locks (estado temporal de sesiones) ─────────────────────────
.claude/sessions/

# ── Personal Vault (N3 — datos personales del usuario, repo independiente) ──
personal-vault/
.savia/

# ── Savia Shield — config local (mask-map con datos reales N4, NUNCA commit) ──
config.local/

# ── ZeroClaw local data (firmware cache, local config, generated audio) ──────
zeroclaw/.cache/
zeroclaw/savia-voice/config.local.yaml
zeroclaw/savia-voice/cache/

# ── Infraestructura local del PM (no parte del producto) ────────────────────
git/
