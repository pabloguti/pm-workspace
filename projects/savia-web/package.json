{
  "name": "savia-web",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const p=require('./package.json');const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "serve": "npx serve dist -l 8081 -s",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "highlight.js": "^11.11.0",
    "lucide-vue-next": "^0.577.0",
    "marked": "^15.0.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^16.8.1",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  }
}
