{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Savia Monitor",
  "version": "0.1.0",
  "identifier": "com.savia.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Savia Monitor",
        "width": 440,
        "height": 700,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
