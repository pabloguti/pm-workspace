{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-init.sh",
            "timeout": 15,
            "statusMessage": "Inicializando sesi\u00f3n PM-Workspace..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-credential-leak.sh",
            "timeout": 5,
            "statusMessage": "Savia Shield: detectando credenciales..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-force-push.sh",
            "timeout": 5,
            "statusMessage": "Savia Shield: bloqueando force-push..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-infra-destructive.sh",
            "timeout": 5,
            "statusMessage": "Savia Shield: bloqueando infra destructiva..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-bash-global.sh",
            "statusMessage": "Validando comando..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-hook-commit.sh",
            "timeout": 5,
            "statusMessage": "Prompt hook: validando sem\u00e1ntica..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/compliance-gate.sh",
            "timeout": 30,
            "statusMessage": "Compliance gate: verificando reglas..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-dispatch-validate.sh",
            "timeout": 5,
            "statusMessage": "Validando contexto del agente..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tool-call-validate.sh",
            "timeout": 5,
            "statusMessage": "Validando par\u00e1metros de tool call..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ast-comprehend-hook.sh",
            "timeout": 15,
            "statusMessage": "AST Comprehension: leyendo mapa estructural..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tdd-gate.sh",
            "timeout": 10,
            "statusMessage": "TDD gate: tests antes que c\u00f3digo..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-gate.sh",
            "statusMessage": "Verificando spec aprobada..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-project-whitelist.sh",
            "timeout": 5,
            "statusMessage": "Verificando privacidad de proyectos..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/data-sovereignty-gate.sh",
            "timeout": 15,
            "statusMessage": "Savia Shield: scanning..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-gitignored-references.sh",
            "timeout": 5,
            "statusMessage": "Checking for gitignored content in public files..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/responsibility-judge.sh",
            "timeout": 5,
            "statusMessage": "Responsibility Judge: evaluando decisi\u00f3n..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-layer-contract.sh",
            "timeout": 5,
            "statusMessage": "SE-001: Core/Enterprise layer contract check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-hook-premerge.sh",
            "timeout": 30,
            "statusMessage": "Agent hook: pre-merge quality gate..."
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tool-call-healing.sh",
            "timeout": 3,
            "statusMessage": "Validando parametros..."
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/live-progress-hook.sh",
            "async": true,
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:8444/gate",
            "headers": {
              "X-Shield-Token": "$SHIELD_TOKEN"
            },
            "allowedEnvVars": [
              "SHIELD_TOKEN"
            ],
            "timeout": 5,
            "statusMessage": "Savia Shield HTTP gate..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-injection-guard.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/delegation-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh",
            "async": true,
            "timeout": 30,
            "statusMessage": "Auto-lint en background..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/memory-auto-capture.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Capturando en memoria..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pbi-history-capture.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Registrando historial PBI..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/token-tracker-middleware.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Monitorizando contexto..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/data-sovereignty-audit.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Savia Shield: auditoria post-escritura..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ast-quality-gate-hook.sh",
            "async": true,
            "timeout": 60,
            "statusMessage": "AST Quality Gate: analizando c\u00f3digo..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dual-estimation-gate.sh",
            "timeout": 5,
            "statusMessage": "Dual Estimation: verificando escalas..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-trace-log.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Registrando traza de agente..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/compress-agent-output.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Comprimiendo output de agente..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-output-compress.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Comprimiendo output de bash..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/competence-tracker.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Registrando competencia..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end-snapshot.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Guardando snapshot de sesi\u00f3n..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-review.sh",
            "timeout": 30,
            "statusMessage": "Revisando ficheros staged..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-quality-gate.sh",
            "timeout": 15,
            "statusMessage": "Verificando quality gates..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-guard.sh",
            "timeout": 10,
            "statusMessage": "Verificando scope de la spec..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-memory-extract.sh",
            "async": true,
            "timeout": 30,
            "statusMessage": "Extrayendo memoria de sesion..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/emotional-regulation-monitor.sh",
            "async": true,
            "timeout": 10,
            "statusMessage": "Evaluando bienestar de sesi\u00f3n..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end-memory.sh",
            "timeout": 1500,
            "statusMessage": "Extrayendo memoria de sesi\u00f3n..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/user-prompt-intercept.sh",
            "timeout": 3000,
            "statusMessage": "Pre-procesando input..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stress-awareness-nudge.sh",
            "timeout": 2000,
            "statusMessage": "Emotional awareness check..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/memory-prime-hook.sh",
            "async": true,
            "timeout": 5000,
            "statusMessage": "Memory context priming..."
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cwd-changed-hook.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact-backup.sh",
            "timeout": 10,
            "statusMessage": "Backup pre-compactaci\u00f3n..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/post-compaction.sh",
            "timeout": 10,
            "statusMessage": "Recuperando memoria persistente tras compactaci\u00f3n..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool-failure-log.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Registrando fallo de herramienta..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-lifecycle.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Tracking agent lifecycle..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-lifecycle.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Logging agent completion..."
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-lifecycle.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Logging task creation..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-lifecycle.sh",
            "async": true,
            "timeout": 5,
            "statusMessage": "Logging task completion..."
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "*.cs|*.py|*.ts|*.tsx|*.js|*.jsx|*.go|*.java|*.rs|*.rb|*.php",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/file-changed-staleness.sh",
            "async": true,
            "timeout": 2,
            "statusMessage": "Checking map staleness..."
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/instructions-tracker.sh",
            "async": true,
            "timeout": 3,
            "statusMessage": "Tracking instructions..."
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/config-reload.sh",
            "async": true,
            "timeout": 3,
            "statusMessage": "Reloading config..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "BASH_MAX_OUTPUT_LENGTH": "80000",
    "TASK_MAX_OUTPUT_LENGTH": "80000",
    "ENABLE_TOOL_SEARCH": "auto",
    "CLAUDE_CODE_NO_FLICKER": "1"
  }
}
